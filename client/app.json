{
  "expo": {
    "name": "Mind Wallet",
    "slug": "client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mind_wallet_icon.png",
    "scheme": "mindwallet",
    "userInterfaceStyle": "automatic",
    "ios": {},
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D0F1A",
        "foregroundImage": "./assets/images/mind_wallet_icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.jusian.mindwallet"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/mind_wallet_icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D0F1A",
          "image": "./assets/images/mind_wallet_icon.png",
          "imageWidth": 200,
          "android": {
            "image": "./assets/images/mind_wallet_icon.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-sharing",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "18ac72bb-9144-4c87-b109-c92430983e2f"
      }
    }
  }
}
